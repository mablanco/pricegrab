<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8.0 / API 26+).

  - <background> is a solid colour that matches the rounded-square frame inside
    `ic_launcher_foreground.png` exactly, so the device's mask sees a uniform
    colour field with the design centred inside the safe zone (66 dp circle).
  - <foreground> is the cropped, padded square frame; the foreground PNGs are
    generated by `branding/regenerate-icons.py` from `branding/icon-source.png`.
  - <monochrome> is intentionally omitted: the multi-colour, textured art does
    not reduce to a meaningful single-colour silhouette without redrawing it
    from scratch. Devices on Android 13+ with the themed-icon toggle enabled
    will fall back to the regular icon, which is the documented graceful path.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>

# =========================================================================
# PriceGrab — .gitignore
# Targets: Android (Gradle + Kotlin + Android Studio / IntelliJ),
#          generic editor/OS noise, and sensitive/local-only material.
# =========================================================================

# -------------------------------------------------------------------------
# Gradle
# -------------------------------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/
!**/src/test/**/build/

# -------------------------------------------------------------------------
# Android build output
# -------------------------------------------------------------------------
*.apk
*.aab
*.ap_
*.dex
*.class
bin/
gen/
out/
release/
captures/
local.properties

# -------------------------------------------------------------------------
# Android Studio / IntelliJ IDEA
# -------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.navigation/
.externalNativeBuild/
.cxx/
!.idea/runConfigurations/

# -------------------------------------------------------------------------
# Kotlin / Java
# -------------------------------------------------------------------------
*.kotlin_module
*.hprof

# -------------------------------------------------------------------------
# Android signing & Google Play (NEVER commit)
# -------------------------------------------------------------------------
*.jks
*.keystore
keystore.properties
signing.properties
google-services.json
play-store-credentials.json

# -------------------------------------------------------------------------
# Testing / coverage / profiling
# -------------------------------------------------------------------------
*.log
test-results/
reports/
coverage/
jacoco.exec

# -------------------------------------------------------------------------
# OS noise
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -------------------------------------------------------------------------
# Editors
# -------------------------------------------------------------------------
*.swp
*.swo
*~
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# -------------------------------------------------------------------------
# Sensitive / local-only (NEVER commit)
# -------------------------------------------------------------------------
# Environment & secrets
.env
.env.*
!.env.example
*.env
secrets/
.secrets/
secret.*
secrets.*
credentials
credentials.*
*.credentials
*credentials.json
auth.json
.auth
.authinfo
.netrc
.pypirc
.npmrc

# Cryptographic material
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.asc
*.gpg
id_rsa
id_ed25519
id_ecdsa
known_hosts

# Cloud / CI provider configs that may carry tokens
.aws/
.gcloud/
.azure/
.terraform/
*.tfstate
*.tfstate.*
.terraformrc
terraform.rc

# AI / IDE assistants — local state, tokens, chat history
.cursor/mcp.json
.cursor/cache/
.cursor/logs/
.cursor/state/
.cursor/projects/
.cursor/agent-transcripts/
.cursor/ai-tracking/
.claude/
.claude-code/
.codex/
.aider*
.continue/
.windsurf/
.cody/
.github-copilot/

# VSCode / editor local history
.history/

# Legacy / non-distributed project sources
*.aia

# -------------------------------------------------------------------------
# Misc
# -------------------------------------------------------------------------
*.tmp
*.bak
